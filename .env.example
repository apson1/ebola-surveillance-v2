# Copy this file to `.env` and fill in the values. Never commit `.env`.

# Gemini (Google AI Studio) — used by the ADK signal pipeline for ranking.
GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.5-flash).
GEMINI_MODEL=

# ReliefWeb live sources (Phase 1). A public request identifier ReliefWeb asks clients to
# send (e.g. your-app-name). If unset, live-source features are disabled and the rest of the
# app runs unchanged.
RELIEFWEB_APPNAME=
# Selects the ACTIVE outbreak (Phase B). This id must match a profile in src/outbreaks.py and the
# disaster_id column in data/history.csv. Default 52586 = DRC Ebola 2026 (EP-2026-000071-COD).
# Changing it re-scopes the whole app to another configured outbreak — a config change, not a
# per-session action.
RELIEFWEB_DISASTER_ID=
